# AgentDash Environment Variables
# Copy this file to .env and fill in your values.

# Server
PORT=3141
HOST=127.0.0.1              # Use 0.0.0.0 to allow LAN access

# CORS — comma-separated origins (defaults to localhost:3141)
# CORS_ORIGIN=http://localhost:3141,http://192.168.1.100:3141

# Nano Banana (AI Visuals) — optional, for UI mockup generation
# Get a free key at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=

# Vite dev server — only needed for development
# VITE_ALLOWED_HOSTS=all
